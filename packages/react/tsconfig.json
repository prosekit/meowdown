{
  "extends": "@ocavue/tsconfig/dom/app.json",
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./src/**/*.module.css",
    "./src/**/*.module.d.css.ts",
    "./*.ts"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowArbitraryExtensions": true,
    "erasableSyntaxOnly": true
  },
  "cmkOptions": { "enabled": true, "dtsOutDir": ".", "arbitraryExtensions": true },
  "references": [
    {
      "path": "../core/tsconfig.json"
    },
    {
      "path": "../vitest/tsconfig.json"
    }
  ]
}
