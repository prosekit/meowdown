{
  "extends": "@ocavue/tsconfig/dom/app.json",
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./src/**/*.module.css",
    "./src/**/*.module.css.d.ts",
    "./*.ts"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "preserve",
    "moduleResolution": "bundler",
    "erasableSyntaxOnly": true
  },
  "cmkOptions": { "enabled": true, "dtsOutDir": "." },
  "references": [{ "path": "../core/tsconfig.json" }]
}
