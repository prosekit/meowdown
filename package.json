{
  "name": "meowdown-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "pnpm --filter ./website run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm run lint:eslint && pnpm run lint:oxfmt && pnpm run lint:knip",
    "lint:oxfmt": "oxfmt --check",
    "lint:eslint": "eslint --cache",
    "lint:knip": "knip",
    "fix": "pnpm run fix:oxfmt && pnpm run fix:eslint",
    "fix:oxfmt": "oxfmt",
    "fix:eslint": "eslint --cache --fix",
    "test": "vitest",
    "test:install": "playwright install chromium",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.0",
    "@ocavue/eslint-config": "^4.0.0",
    "@ocavue/tsconfig": "^0.7.0",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.0",
    "knip": "^6.0.0",
    "oxfmt": "^0.53.0",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
