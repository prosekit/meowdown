{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/v17.7.0/schemas/config.json",
  "bump-minor-pre-major": true,
  "always-update": true,
  "packages": {
    "packages/core": {
      "component": "core"
    },
    "packages/markdown": {
      "component": "markdown"
    },
    "packages/react": {
      "component": "react"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "meowdown",
      "components": ["core", "markdown", "react"]
    }
  ]
}
